class _C {
  static const bg          = Color(0xFF07090F);
  static const surface     = Color(0xFF0F1520);
  static const card        = Color(0xFF131B2E);
  static const cardBorder  = Color(0xFF1C2B45);
  static const primary     = Color(0xFF7C6FF7);
  static const accent      = Color(0xFF06D6A0);
  static const accentGold  = Color(0xFFFFD166);
  static const textSub     = Color(0xFF6B7A99);
  static const textPrimary = Color(0xFFE8EAF6);

  static const grad1 = [Color(0xFF7C6FF7), Color(0xFF4F46E5)];
  static const grad2 = [Color(0xFF06D6A0), Color(0xFF118AB2)];
  static const grad3 = [Color(0xFFFF6B6B), Color(0xFFFF9A3C)];
  static const grad4 = [Color(0xFFFFD166), Color(0xFFFF9A3C)];

  static const riskLow      = Color(0xFF4CAF50);
  static const riskModerate = Color(0xFFFF9800);
  static const riskHigh     = Color(0xFFF44336);
  static const riskUnknown  = Color(0xFF6B7A99);

  static String _toTitleCase(String s) => s.split('_').map((w) => w.isEmpty ? '' : w[0].toUpperCase() + w.substring(1)).join(' ');
}

class AssessmentScreen extends StatefulWidget {
  const AssessmentScreen({super.key});
  @override
  State<AssessmentScreen> createState() => _AssessmentScreenState();
}

class _AssessmentScreenState extends State<AssessmentScreen> {
  List<Assessment> _assessments = [];
  String _overallRisk = 'unknown';
  bool _loading = true;
  int _lastMessageCount = 0;
  Map<String, int> _localAnswers = {};

  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addPostFrameCallback((_) => _load());
  }

  Future<void> _load() async {
    setState(() => _loading = true);
    try {
      final chat = context.read<ChatProvider>();
      if (chat.sessionId != null) {
        final resp = await ApiService().getAssessmentStatus(chat.sessionId!);
        if (mounted) {
          setState(() {
            _assessments = resp.assessments;
            _overallRisk = resp.overallRisk;
            _loading = false;
          });
        }
        return;
      }
    } catch (e) {}
    if (mounted) {
      setState(() {
        _assessments = _getDefaultAssessments();
        _overallRisk = _calculateLocalRisk();
        _loading = false;
      });
    }
  }

  List<Assessment> _getDefaultAssessments() {
    return [
      Assessment(name: 'PHQ-9', fullName: 'Patient Health Questionnaire-9', domain: 'Depression', score: 0, answered: 0, totalQuestions: 9, completionPct: 0, severity: 'Minimal depression', severityColor: '#4CAF50', interpretation: 'Screens for depressive disorder severity.', questions: _phq9Questions()),
      Assessment(name: 'GAD-7', fullName: 'Generalized Anxiety Disorder-7', domain: 'Anxiety', score: 0, answered: 0, totalQuestions: 7, completionPct: 0, severity: 'Minimal anxiety', severityColor: '#4CAF50', interpretation: 'Screens for generalized anxiety disorder.', questions: _gad7Questions()),
      Assessment(name: 'PSS-10', fullName: 'Perceived Stress Scale-10', domain: 'Stress', score: 0, answered: 0, totalQuestions: 10, completionPct: 0, severity: 'Low stress', severityColor: '#4CAF50', interpretation: 'Measures perceived stress level.', questions: _pss10Questions()),
      Assessment(name: 'SPIN', fullName: 'Social Phobia Inventory', domain: 'Social Anxiety', score: 0, answered: 0, totalQuestions: 17, completionPct: 0, severity: 'No social phobia', severityColor: '#4CAF50', interpretation: 'Screens for social anxiety disorder.', questions: _spinQuestions()),
    ];
  }

  List<AssessmentQuestion> _phq9Questions() => [
    AssessmentQuestion(id: 'phq1', text: 'Little interest or pleasure in doing things?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'phq2', text: 'Feeling down, depressed, or hopeless?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'phq3', text: 'Trouble falling or staying asleep, or sleeping too much?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'phq4', text: 'Feeling tired or having little energy?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'phq5', text: 'Poor appetite or overeating?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'phq6', text: 'Feeling bad about yourself or that you are a failure?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'phq7', text: 'Trouble concentrating on things?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'phq8', text: 'Moving or speaking slowly, or being fidgety/restless?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'phq9', text: 'Thoughts of hurting yourself or being better off dead?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
