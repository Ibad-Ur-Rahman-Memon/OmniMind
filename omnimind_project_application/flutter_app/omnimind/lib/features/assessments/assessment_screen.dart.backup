    AssessmentQuestion(id: 'spin6', text: 'Sweating in front of people causes me distress.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin7', text: 'I avoid going to parties.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin8', text: 'I avoid activities in which I am center of attention.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin9', text: 'Talking to strangers scares me.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin10', text: 'I avoid having to give speeches.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin11', text: 'I would do anything to avoid being criticized.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin12', text: 'Heart palpitations when with other people.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin13', text: 'I am afraid of doing things when people might be watching.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin14', text: 'Being embarrassed or looking stupid are my worst fears.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin15', text: 'I avoid speaking to authority figures.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin16', text: 'Trembling or shaking in front of others is distressing.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
  ];

  String _calculateLocalRisk() {
    int phq = 0, gad = 0, pss = 0, spin = 0;
    for (final a in _assessments) {
      final name = a.name.toUpperCase();
      if (name.contains('PHQ')) phq = a.score;
      else if (name.contains('GAD')) gad = a.score;
      else if (name.contains('PSS')) pss = a.score;
      else if (name.contains('SPIN')) spin = a.score;
    }
    if (phq >= 20 || gad >= 15) return 'high';
    if (phq >= 10 || gad >= 10 || pss >= 27) return 'moderate';
    if (phq >= 5 || gad >= 5 || pss >= 14) return 'low';
    return 'unknown';
  }

  void _onAnswer(String assessmentName, String questionId, int score) {
    final key = '${assessmentName}_$questionId';
    setState(() {
      _localAnswers[key] = score;
      _recalculateScores();
      _overallRisk = _calculateLocalRisk();
    });
    _syncToBackend(assessmentName, questionId, score);
  }

  void _recalculateScores() {
    for (int i = 0; i < _assessments.length; i++) {
      final a = _assessments[i];
      int total = 0, answered = 0;
      for (final q in a.questions) {
        final key = '${a.name}_${q.id}';
        if (_localAnswers.containsKey(key)) {
          total += _localAnswers[key]!;
          answered++;
        }
      }
      _assessments[i] = Assessment(
        name: a.name, fullName: a.fullName, domain: a.domain, score: total,
        answered: answered, totalQuestions: a.questions.length,
        completionPct: (answered / a.questions.length * 100),
        severity: a.severity, severityColor: a.severityColor, interpretation: a.interpretation,
        questions: a.questions,
      );
    }
  }

  Future<void> _syncToBackend(String assessmentName, String questionId, int score) async {
    try {
      final chat = context.read<ChatProvider>();
      if (chat.sessionId != null) {
        await ApiService().submitAssessmentAnswer(
          sessionId: chat.sessionId!, assessmentName: assessmentName,
          questionId: questionId, score: score,
        );
      }
    } catch (_) {}
  }

  Color _riskColor(String risk) {
    switch (risk.toLowerCase()) {
      case 'high': return _C.riskHigh;
      case 'moderate': return _C.riskModerate;
      case 'low': return _C.riskLow;
      default: return _C.riskUnknown;
    }
  }

  @override
  Widget build(BuildContext context) {
    return Consumer<ChatProvider>(builder: (context, chat, _) {
      if (_assessments.isEmpty && _loading) {
        return Scaffold(backgroundColor: _C.bg, body: Center(child: CircularProgressIndicator(color: _C.primary)));
      }
      return Scaffold(backgroundColor: _C.bg, appBar: AppBar(title: Text('Assessments', style: GoogleFonts.poppins(fontWeight: FontWeight.w600)), backgroundColor: _C.surface, foregroundColor: Colors.white, elevation: 0),
        body: RefreshIndicator(onRefresh: _load, color: _C.primary,
          child: SingleChildScrollView(
            physics: AlwaysScrollableScrollPhysics(),
            padding: EdgeInsets.all(16),
            child: Column(children: [
              _buildOverallRiskCard(),
              SizedBox(height: 16),
              ..._assessments.asMap().entries.map((e) => _AssessmentCard(assessment: e.value, onAnswer: (qId, score) => _onAnswer(e.value.name, qId, score)).animate().fadeIn(delay: Duration(milliseconds: e.key * 100))),
            ]),
          ),
        ),
      );
    });
  }

  Widget _buildOverallRiskCard() {
    final color = _riskColor(_overallRisk);
    final riskLabels = {'unknown': 'UNKNOWN', 'low': 'LOW RISK', 'moderate': 'MODERATE RISK', 'high': 'HIGH RISK'};
    return Container(padding: EdgeInsets.all(20), decoration: BoxDecoration(gradient: LinearGradient(colors: [color.withOpacity(0.2), color.withOpacity(0.05)], begin: Alignment.topLeft, end: Alignment.bottomRight), borderRadius: BorderRadius.circular(16), border: Border.all(color: color.withOpacity(0.3)),
      child: Column(children: [
        Row(mainAxisAlignment: MainAxisAlignment.center, children: [Text(riskLabels[_overallRisk] ?? 'UNKNOWN', style: GoogleFonts.poppins(fontSize: 20, fontWeight: FontWeight.bold, color: color))]),
        SizedBox(height: 8),
        Text(_overallRisk == 'unknown' ? 'Start answering questions to see your risk level' : 'Based on your assessment responses', style: GoogleFonts.poppins(fontSize: 12, color: _C.textSub)),
      ]),
    );
  }
}

class _AssessmentCard extends StatefulWidget {
  final Assessment assessment;
  final Function(String, int) onAnswer;
  const _AssessmentCard({required this.assessment, required this.onAnswer});
  @override
  State<_AssessmentCard> createState() => _AssessmentCardState();
}

class _AssessmentCardState extends State<_AssessmentCard> {
  bool _expanded = false;
  int _maxScoreFor(String name) { final n = name.toUpperCase(); if (n.contains('PHQ')) return 27; if (n.contains('GAD')) return 21; if (n.contains('PSS')) return 40; if (n.contains('SPIN')) return 68; return 100; }
  List<Color> _getGrad(String domain) { switch (domain.toLowerCase()) { case 'depression': return _C.grad3; case 'anxiety': return _C.grad1; case 'stress': return _C.grad4; default: return _C.grad2; } }
  String _getIcon(String domain) { switch (domain.toLowerCase()) { case 'depression': return '💔'; case 'anxiety': return '😰'; case 'stress': return '😣'; default: return '😟'; } }

  @override
  Widget build(BuildContext context) {
    final maxScore = _maxScoreFor(widget.assessment.name);
    final pct = maxScore > 0 ? widget.assessment.score / maxScore : 0.0;
    final color = Color(int.parse(widget.assessment.severityColor.replaceFirst('#', '0xFF')));
    return Container(margin: EdgeInsets.only(bottom: 12), decoration: BoxDecoration(color: _C.card, borderRadius: BorderRadius.circular(16), border: Border.all(color: _C.cardBorder)),
      child: Column(children: [
        InkWell(onTap: () => setState(() => _expanded = !_expanded),
          child: Padding(padding: EdgeInsets.all(16), child: Row(children: [
            Container(width: 48, height: 48, decoration: BoxDecoration(gradient: LinearGradient(colors: _getGrad(widget.assessment.domain)), borderRadius: BorderRadius.circular(12)), child: Center(child: Text(_getIcon(widget.assessment.domain), style: TextStyle(fontSize: 24)))),
            SizedBox(width: 12),
            Expanded(child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
              Text(widget.assessment.name, style: GoogleFonts.poppins(fontSize: 16, fontWeight: FontWeight.w600, color: Colors.white)),
              Text('${widget.assessment.score}/${maxScore}', style: GoogleFonts.poppins(fontSize: 12, color: _C.textSub)),
            ])),
            CircularPercentIndicator(radius: 24, lineWidth: 4, percent: pct.clamp(0.0, 1.0), progressColor: color, backgroundColor: color.withOpacity(0.2), center: Text('${(pct * 100).round()}%', style: GoogleFonts.poppins(fontSize: 9, fontWeight: FontWeight.w600))),
            SizedBox(width: 8),
            Icon(_expanded ? Icons.expand_less : Icons.expand_more, color: _C.textSub),
          ])),
        ),
        if (_expanded) Container(padding: EdgeInsets.fromLTRB(16, 0, 16, 16), child: Column(children: [
          LinearPercentIndicator(leading: Text('Completion', style: GoogleFonts.poppins(fontSize: 10, color: _C.textSub)), percent: (widget.assessment.completionPct / 100).clamp(0.0, 1.0), progressColor: _C.accent, backgroundColor: _C.surface, barRadius: Radius.circular(4), padding: EdgeInsets.zero, lineHeight: 6),
          SizedBox(height: 12),
          ...widget.assessment.questions.map((q) => _QuestionRow(question: q, onAnswer: (s) => widget.onAnswer(q.id, s))),
        ])),
      ]),
    );
  }
}

class _QuestionRow extends StatelessWidget {
  final AssessmentQuestion question;
  final Function(int) onAnswer;
  const _QuestionRow({required this.question, required this.onAnswer});
  @override
  Widget build(BuildContext context) {
    return Container(margin: EdgeInsets.only(bottom: 8), padding: EdgeInsets.all(12), decoration: BoxDecoration(color: _C.surface, borderRadius: BorderRadius.circular(12), border: Border.all(color: _C.cardBorder)),
      child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
        Text(question.text, style: GoogleFonts.poppins(fontSize: 12, fontWeight: FontWeight.w500, color: Colors.white)),
        SizedBox(height: 8),
        Wrap(spacing: 6, runSpacing: 6, children: List.generate(question.options.length, (i) => GestureDetector(
          onTap: () => onAnswer(question.scores[i]),
          child: Container(padding: EdgeInsets.symmetric(horizontal: 10, vertical: 6), decoration: BoxDecoration(color: _C.card, borderRadius: BorderRadius.circular(8), border: Border.all(color: _C.cardBorder)),
            child: Text(question.options[i], style: GoogleFonts.poppins(fontSize: 11, color: _C.textSub)),
          ),
        ))),
      ]),
    );
  }
}
