  List<AssessmentQuestion> _spinQuestions() => [
    AssessmentQuestion(id: 'spin1', text: 'I am afraid of people in authority.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin2', text: 'I am bothered by blushing in front of people.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin3', text: 'Parties and social events scare me.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
    AssessmentQuestion(id: 'spin4', text: 'I avoid talking to people I do not know.', options: ['Not at all', 'A little bit', 'Somewhat', 'Very much', 'Extremely'], scores: [0, 1, 2, 3, 4]),
