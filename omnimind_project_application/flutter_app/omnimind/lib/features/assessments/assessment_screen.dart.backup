    AssessmentQuestion(id: 'gad2', text: 'Not being able to stop or control worrying?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'gad3', text: 'Worrying too much about different things?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'gad4', text: 'Trouble relaxing?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'gad5', text: 'Being so restless that it is hard to sit still?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'gad6', text: 'Becoming easily annoyed or irritable?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
    AssessmentQuestion(id: 'gad7', text: 'Feeling afraid as if something awful might happen?', options: ['Not at all', 'Several days', 'More than half', 'Nearly every day'], scores: [0, 1, 2, 3]),
  ];

  List<AssessmentQuestion> _pss10Questions() => [
